# Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=edusgent
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=edusgent

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================
# LLM Provider Configuration
# ============================================================
# Supported providers: "spark" (讯飞星火) or "deepseek"
LLM_PROVIDER=spark

# ----------------------------------------------------------
# 讯飞星火 API Configuration (主用)
# 获取方式: https://xinghuo.xfyun.cn/
# ----------------------------------------------------------
SPARK_APP_ID=your_spark_app_id_here
SPARK_API_KEY=your_spark_api_key_here
SPARK_API_SECRET=your_spark_api_secret_here
SPARK_VERSION=v3.5
# 可选值: v1.5 / v2.0 / v3.0 / v3.5
# 对应域名:
#   v1.5  -> general
#   v2.0  -> generalv2
#   v3.0  -> generalv3
#   v3.5  -> generalv3.5

# ----------------------------------------------------------
# DeepSeek API Configuration (备选)
# ----------------------------------------------------------
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================================
# Application Configuration
# ============================================================
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# LangGraph Configuration
LANGGRAPH_CHECKPOINT_ENABLED=true
LANGGRAPH_CHECKPOINT_DB=sqlite

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
